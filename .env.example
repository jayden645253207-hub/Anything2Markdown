# Anything2Markdown - Environment Variables
#
# Copy this file to .env and fill in the values you need.
# All keys are optional; populate only the providers you actually use.

# --- I/O paths -------------------------------------------------------------
INPUT_DIR=./input
OUTPUT_DIR=./output
LOG_DIR=./logs

# --- API keys --------------------------------------------------------------
# SiliconFlow — required for PaddleOCR-VL (scanned PDF / image OCR fallback)
# Sign up: https://siliconflow.cn/
SILICONFLOW_API_KEY=

# MinerU — optional alternative PDF backend (currently available only as OCR fallback)
# Sign up: https://mineru.net/
MINERU_API_KEY=

# Firecrawl — required only for `parse-url` on general web pages.
# Sign up: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=

# --- Routing strategy ------------------------------------------------------
# token_efficient : try text-layer first, then non-LLM OCR (cheapest path)
# balanced        : use the original parser chain
PARSING_STRATEGY=token_efficient
PDF_PROBE_PAGES=3
PDF_TEXT_LAYER_MIN_CHARS=80
SCANNED_PDF_PARSER=paddle_text
IMAGE_OCR_PARSER=paddle_text
PDF_OCR_FALLBACK_PARSER=paddle_text
PADDLE_DOC_MAX_PDF_PAGES=100

# --- MinerU configuration --------------------------------------------------
MINERU_API_ENDPOINT=https://mineru.net/api/v4/extract/task
MAX_PDF_SIZE_MB=10
MIN_VALID_CHARS=500
MINERU_PAGES_PER_SPLIT=400

# --- PaddleOCR-VL (scanned-PDF OCR fallback) ------------------------------
PADDLEOCR_MODEL=PaddlePaddle/PaddleOCR-VL-1.5
OCR_DPI=150
OCR_PAGE_TIMEOUT=60
# OCR_BASE_URL=                       # empty = SiliconFlow; http://localhost:8080 = local

# --- PaddleOCR text/doc API (preferred for low-token OCR) ------------------
PADDLEOCR_ACCESS_TOKEN=
PADDLEOCR_OCR_API_URL=
PADDLEOCR_OCR_TIMEOUT=120
PADDLEOCR_DOC_PARSING_API_URL=
PADDLEOCR_DOC_PARSING_TIMEOUT=600

# --- External OCR command slot (e.g. a custom local OCR script) -----------
MANNER_OCR_COMMAND=
MANNER_OCR_TIMEOUT=600

# --- Bilibili parser -------------------------------------------------------
BILIBILI_COOKIES_FILE=
BILIBILI_COOKIES_FROM_BROWSER=
WHISPERX_MODEL=small

# --- General ---------------------------------------------------------------
MAX_WORKERS=4
RETRY_COUNT=1
RETRY_DELAY_SECONDS=2

# Logging — DEBUG / INFO / WARNING / ERROR; format = json / text / both
LOG_LEVEL=INFO
LOG_FORMAT=both

# Output language for LLM prompts: en (default) or zh
LANGUAGE=en
